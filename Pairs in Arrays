public class pairs {
    public static void main(String[] args) {
        int a[] = {9,9,8,3,8,3,9,5,1,2,2,5,5,9,5,7,0,1};
        for(int i=0;i<a.length;i++)
        {
            int f=0;
            for(int j=i;j>=0;j--)
            {
                if(a[i]==a[j])
                {
                    f++;
                }
            }
            if(f%2==0)
            {
                System.out.println(a[i]+" "+a[i]);
            }
        }
    }
}
